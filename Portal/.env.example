# Authentication
# This app requires Azure App Service Easy Auth (Microsoft Entra ID) for user sign-in.
# No app-managed Azure AD client secret is used by this runtime.
APP_BASE_URL=http://localhost:3000

# Azure Key Vault
KEY_VAULT_URI=https://your-keyvault.vault.azure.net

# Azure Log Analytics
LOG_ANALYTICS_WORKSPACE_ID=your-workspace-id-here
LOG_ANALYTICS_SHARED_KEY=your-shared-key-here
LOG_ANALYTICS_LOG_TYPE=CloudLAPSAudit

# Application Settings
NODE_ENV=development
PORT=3000
TRUST_PROXY=0

# Logging
LOG_LEVEL=info
